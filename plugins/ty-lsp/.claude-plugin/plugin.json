{
  "name": "ty-lsp",
  "description": "Python language server (ty) for Claude Code",
  "version": "1.0.0",
  "author": {
    "name": "Andreas Spannagel"
  },
  "homepage": "https://github.com/astral-sh/ty",
  "license": "MIT",
  "lspServers": {
    "ty": {
      "command": "uvx",
      "args": ["ty@latest", "server"],
      "extensionToLanguage": {
        ".py": "python",
        ".pyi": "python"
      }
    }
  }
}
